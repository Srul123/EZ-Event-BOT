NODE_ENV=development
PORT=3000
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_BOT_USERNAME=EzEventBot
# 127.0.0.1 avoids Windows/Node resolving localhost to ::1 when MongoDB listens on IPv4 only
MONGODB_URI=mongodb://127.0.0.1:27017/ez-event-bot
LOG_LEVEL=info
ANTHROPIC_API_KEY=your_anthropic_api_key_here
RSVP_USE_LLM_INTERPRETATION=true
RSVP_USE_LLM_RESPONSES=true
RSVP_CONFIDENCE_THRESHOLD=0.85
LOG_LEVEL=debug